<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="30dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarCategorias"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1B263B"
            app:title="Ranking de Categorías"
            app:titleTextColor="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="#1B263B">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FILTRAR POR FECHAS"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <ImageButton
                android:id="@+id/btnFiltroCategoriasGeneral"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_boton_redondo"
                android:src="@android:drawable/ic_menu_today"
                android:contentDescription="Filtrar"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnLimpiarFiltroCategorias"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_boton_redondo"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Limpiar"
                app:tint="#FF4C4C" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:text="TUS CATEGORÍAS FAVORITAS"
            android:textColor="#A9D6E5"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="bottom|center_horizontal"
                android:orientation="vertical">
                <TextView android:id="@+id/tvMontoPlata" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$0" android:textColor="#C0C0C0" android:textStyle="bold"/>
                <View android:layout_width="match_parent" android:layout_height="100dp" android:background="#1B263B" android:layout_marginHorizontal="4dp" android:backgroundTint="#80C0C0C0"/>
                <TextView android:id="@+id/tvNombrePlata" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="1" android:ellipsize="end"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:gravity="bottom|center_horizontal"
                android:orientation="vertical">
                <TextView android:id="@+id/tvMontoOro" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$0" android:textColor="#FFD700" android:textSize="18sp" android:textStyle="bold"/>
                <View android:layout_width="match_parent" android:layout_height="140dp" android:background="#1B263B" android:layout_marginHorizontal="4dp" android:backgroundTint="#80FFD700"/>
                <TextView android:id="@+id/tvNombreOro" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#FFFFFF" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="bottom|center_horizontal"
                android:orientation="vertical">
                <TextView android:id="@+id/tvMontoBronce" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$0" android:textColor="#CD7F32" android:textStyle="bold"/>
                <View android:layout_width="match_parent" android:layout_height="70dp" android:background="#1B263B" android:layout_marginHorizontal="4dp" android:backgroundTint="#80CD7F32"/>
                <TextView android:id="@+id/tvNombreBronce" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="1" android:ellipsize="end"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTopCategorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:nestedScrollingEnabled="false" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1B263B" android:layout_margin="20dp"/>

        <TextView
            android:id="@+id/tvTituloMirarPorCartera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="MIRAR POR CARTERA:"
            android:textColor="#A9D6E5"
            android:textSize="12sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCarterasParaCategorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>