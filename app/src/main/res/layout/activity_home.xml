<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0D1B2A"
            app:titleTextColor="#FFFFFF" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1B263B">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TU SALDO DE CARTERA:"
                    android:textColor="#88FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvSaldoCartera"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 0.00"
                    android:textColor="#00FF88"
                    android:textSize="40sp"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCIONES RÁPIDAS"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTransferirDinero"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_marginEnd="15dp"
                    app:backgroundTint="#1B263B"
                    app:strokeColor="#4CC9F0"
                    app:strokeWidth="2dp"
                    app:cornerRadius="28dp"
                    app:icon="@android:drawable/ic_menu_send"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="25dp"
                    app:iconTint="#4CC9F0"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:contentDescription="Transferir entre carteras" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHablarMic"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    app:backgroundTint="#E0E1DD"
                    app:cornerRadius="35dp"
                    app:icon="@android:drawable/ic_btn_speak_now"
                    app:iconSize="35dp"
                    app:iconTint="#000000"
                    app:elevation="6dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:contentDescription="Botón de dictado por voz" />

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AGREGAR MANUALMENTE"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:weightSum="3"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddIngreso"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="INGRESO"
                android:textSize="11sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="#2D6A4F"
                app:icon="@android:drawable/ic_input_add" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddGasto"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="GASTO"
                android:textSize="11sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="#D00000"
                app:icon="@android:drawable/ic_delete" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTransferirAhorro"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:text="AHORRO"
                android:textSize="11sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="#4361EE"
                app:icon="@android:drawable/ic_menu_save" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HISTORIAL RECIENTE"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnFiltroTiempo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_today"
                android:scaleType="centerInside"
                app:tint="#A9D6E5"
                android:contentDescription="Filtrar por fecha y orden" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGastos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Lista de movimientos financieros"
            android:clipToPadding="false"
            android:paddingBottom="24dp" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>